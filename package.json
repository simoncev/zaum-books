{
  "main": "electron-dist/main.js",
  "name": "org.genrep.booksreader",
  "description": "Genrep Electron Book Reader",
  "author": "Kliment Simonchev",
  "version": "0.0.1",
  "scripts": {
    "electron:dev": "tsc -p electron/tsconfig.json && electron .",
    "electron:prod": "tsc -p electron/tsconfig.json && electron . --prod",
    "vite-build": "vite build && tsc -p electron/tsconfig.json",
    "vite-build-electron": "vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run vite-build && electron-builder",
    "dev": "vite --mode dev",
    "pwa:build": "vite build",
    "pwa:preview": "vite preview --host --port 4173",
    "pwa:build-netlify": "vite build --mode netlify",
    "pwa": "npm run pwa:build && npm run pwa:preview"
  },
  "build": {
    "appId": "org.genrep.booksreader",
    "productName": "Books Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron-dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^39.2.7",
    "vite-plugin-pwa": "^1.2.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "vite": "^8.0.8"
  }
}
